<!-- Post-build PE finalizer console app for the BLSE loader exes.
     Adds the dedicated-GPU hint AND sets 4 MB stack reserve / 16 KB commit to
     match Bannerlord.exe — both in one PE rewrite via AsmResolver.

     Built on-demand by the loader csprojs if the output assembly is missing.
     Invoked via <Exec Command="dotnet ...dll <loader.exe>" /> rather than as an
     MSBuild task, because UsingTask references are resolved at project-load
     time and can't see a DLL that the same build session is going to produce. -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>12.0</LangVersion>
    <Nullable>enable</Nullable>
    <RootNamespace>Bannerlord.BLSE.BuildTasks</RootNamespace>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <IsPackable>false</IsPackable>
    <!-- Skip the repo's Directory.Build.props/targets — they set Bannerlord
         reference assemblies and friends that this tool doesn't care about. -->
    <ImportDirectoryBuildProps>false</ImportDirectoryBuildProps>
    <ImportDirectoryBuildTargets>false</ImportDirectoryBuildTargets>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="AsmResolver.DotNet" Version="5.5.1" />
  </ItemGroup>

</Project>
