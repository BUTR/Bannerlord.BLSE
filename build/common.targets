<!--EXTERNAL_PROPERTIES: BANNERLORD_GAME_DIR;BANNERLORD_STABLE_DIR;BANNERLORD_BETA_DIR-->
<Project>

  <Target Name="WarningsForEnvs" BeforeTargets="BeforeCompile">
    <Warning Condition="$(BANNERLORD_GAME_DIR) == '' AND $(BANNERLORD_STABLE_DIR) == '' AND $(BANNERLORD_BETA_DIR) == ''" Text="Environment variable 'BANNERLORD_GAME_DIR' is not set!"></Warning>
    <Warning Condition="$(BANNERLORD_GAME_DIR) == '' AND $(BANNERLORD_STABLE_DIR) == ''" Text="Environment variable 'BANNERLORD_STABLE_DIR' is not set!"></Warning>
    <Warning Condition="$(BANNERLORD_GAME_DIR) == '' AND $(BANNERLORD_BETA_DIR) == ''" Text="Environment variable 'BANNERLORD_BETA_DIR' is not set!"></Warning>
  </Target>

  <UsingTask TaskName="GZip" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <Files ParameterType="Microsoft.Build.Framework.ITaskItem[]"  Required="true" />
      <Result ParameterType="Microsoft.Build.Framework.ITaskItem[]" Output="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System.IO" />
      <Using Namespace="System.IO.Compression" />
      <Code Type="Fragment" Language="cs">
        <![CDATA[
if (Files.Length > 0)
{
    Result = new TaskItem[Files.Length];
    for (var i = 0; i < Files.Length; i++)
    {
        ITaskItem item = Files[i];
        string sourcePath = item.GetMetadata("FullPath");
        string sourceLink = item.GetMetadata("Link");
        string sourceItemSpec = item.ItemSpec;
              
        string destinationSuffix = ".gz";
        string sourceDirectory = Path.GetDirectoryName(sourcePath);
        string destinationPath = Path.Combine(sourceDirectory, sourceLink + destinationSuffix);
        
        string destinationItemDirectory = Path.GetDirectoryName(sourceItemSpec);
        string destinationItemSpec = Path.Combine(destinationItemDirectory, sourceLink + destinationSuffix);

        Log.LogMessage(MessageImportance.Normal, $"EmbeddedResource Src: {sourceItemSpec}");
              
        using (var sourceStream = File.OpenRead(sourcePath))
        using (var destinationStream = new FileStream(destinationPath, FileMode.OpenOrCreate, FileAccess.Write))
        using (var destinationGZip = new GZipStream(destinationStream, CompressionLevel.Optimal))
        {
            destinationStream.SetLength(0);
            sourceStream.CopyTo(destinationGZip);
        }
              
        var destinationItem = new TaskItem(destinationItemSpec);
        
        Log.LogMessage(MessageImportance.Normal, $"EmbeddedResource GZip: {destinationItem.ItemSpec}");
              
        Result[i] = destinationItem;
    }
}
  ]]>
      </Code>
    </Task>
  </UsingTask>

  <UsingTask TaskName="PatchPEStackReserve" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <TargetFile ParameterType="System.String" Required="true" />
      <StackReserve ParameterType="System.UInt64" Required="true" />
      <StackCommit ParameterType="System.UInt64" Required="false" />
      <SetILOnly ParameterType="System.Boolean" Required="false" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.IO" />
      <Code Type="Fragment" Language="cs">
        <![CDATA[
// Bannerlord.exe reserves a 4 MB main-thread stack; .NET SDK winexe defaults
// to 1 MB. v1.4.3's video decoder path needs >1 MB of native stack, so when
// our loader hosts the game the main thread runs out and SOs at the first
// PlayVideo call. Bump the PE header SizeOfStackReserve to match. Optionally
// also set the CLR header IL_ONLY flag (the .NET SDK leaves it off for our
// loaders for reasons that aren't entirely clear; Bannerlord.exe has it set).
var bytes = File.ReadAllBytes(TargetFile);
var peOff = BitConverter.ToInt32(bytes, 0x3C);
if (peOff <= 0 || peOff + 0x70 > bytes.Length || bytes[peOff] != 'P' || bytes[peOff + 1] != 'E')
{
    Log.LogError($"PatchPEStackReserve: '{TargetFile}' is not a valid PE file");
    return false;
}
var coffOff = peOff + 4;
var numSections = BitConverter.ToUInt16(bytes, coffOff + 0x02);
var sizeOptHdr  = BitConverter.ToUInt16(bytes, coffOff + 0x10);
var optOff = coffOff + 0x14;
var magic = BitConverter.ToUInt16(bytes, optOff + 0x00);
if (magic != 0x20B)
{
    Log.LogError($"PatchPEStackReserve: '{TargetFile}' is not PE32+ (magic 0x{magic:X4}); refusing to patch");
    return false;
}

// Stack reserve/commit live in the PE32+ optional header.
var reserveOff = optOff + 0x48;
var commitOff  = optOff + 0x50;
var oldReserve = BitConverter.ToUInt64(bytes, reserveOff);
Buffer.BlockCopy(BitConverter.GetBytes(StackReserve), 0, bytes, reserveOff, 8);
if (StackCommit > 0)
    Buffer.BlockCopy(BitConverter.GetBytes(StackCommit), 0, bytes, commitOff, 8);

var flagsMsg = string.Empty;
if (SetILOnly)
{
    // COMDescriptor is data directory index 14 (each entry 8 bytes), at optOff+0x70 for PE32+.
    var ddOff = optOff + 0x70;
    var clrRva  = BitConverter.ToUInt32(bytes, ddOff + 14 * 8);
    var clrSize = BitConverter.ToUInt32(bytes, ddOff + 14 * 8 + 4);
    if (clrRva == 0 || clrSize < 0x48)
    {
        Log.LogMessage(MessageImportance.High, $"PatchPEStackReserve: '{Path.GetFileName(TargetFile)}' has no CLR header; skipping IL_ONLY");
    }
    else
    {
        // Resolve CLR header RVA -> file offset via section table.
        var sectOff = optOff + sizeOptHdr;
        var clrFileOff = 0;
        for (var i = 0; i < numSections; i++)
        {
            var so = sectOff + i * 40;
            var virtAddr = BitConverter.ToUInt32(bytes, so + 0x0C);
            var virtSize = BitConverter.ToUInt32(bytes, so + 0x08);
            var rawAddr  = BitConverter.ToUInt32(bytes, so + 0x14);
            if (clrRva >= virtAddr && clrRva < virtAddr + virtSize)
            {
                clrFileOff = (int)(rawAddr + (clrRva - virtAddr));
                break;
            }
        }
        if (clrFileOff == 0)
        {
            Log.LogError($"PatchPEStackReserve: could not map CLR header RVA in '{TargetFile}'");
            return false;
        }
        var flagsFileOff = clrFileOff + 0x10;
        var oldFlags = BitConverter.ToUInt32(bytes, flagsFileOff);
        var newFlags = oldFlags | 0x00000001u; // COMIMAGE_FLAGS_ILONLY
        Buffer.BlockCopy(BitConverter.GetBytes(newFlags), 0, bytes, flagsFileOff, 4);
        flagsMsg = $", CLR flags 0x{oldFlags:X8} -> 0x{newFlags:X8}";
    }
}

// Zero the PE checksum (PE+0x58, 4 bytes). Windows does not validate it for
// user-mode executables, but a stale checksum can trip some AV heuristics.
Array.Clear(bytes, peOff + 0x58, 4);
File.WriteAllBytes(TargetFile, bytes);
Log.LogMessage(MessageImportance.High, $"PatchPEStackReserve: '{Path.GetFileName(TargetFile)}' stack reserve {oldReserve:N0} -> {StackReserve:N0}{flagsMsg}");
        ]]>
      </Code>
    </Task>
  </UsingTask>

  <UsingTask TaskName="VerifyGZip" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <Files ParameterType="Microsoft.Build.Framework.ITaskItem[]" Required="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System.IO" />
      <Using Namespace="System.IO.Compression" />
      <Code Type="Fragment" Language="cs">
        <![CDATA[
foreach (ITaskItem item in Files)
{
    string path = item.GetMetadata("FullPath");
    try
    {
        using (var fs = File.OpenRead(path))
        using (var gz = new GZipStream(fs, CompressionMode.Decompress))
        using (var ms = new MemoryStream())
        {
            gz.CopyTo(ms);
            Log.LogMessage(MessageImportance.Normal, $"VerifyGZip OK: {path} ({ms.Length:N0} bytes decompressed)");
        }
    }
    catch (Exception ex)
    {
        Log.LogError($"VerifyGZip FAILED for {path}: {ex.GetType().Name}: {ex.Message}");
    }
}
        ]]>
      </Code>
    </Task>
  </UsingTask>

</Project>